# App
NODE_ENV=development
LOG_LEVEL=info

# Local SQLite/libSQL
APP_ROOT=.
DATABASE_URL=file:./data/ai-flow-builder.db

# disabled | openai | fake
AI_PROVIDER=disabled

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=

# Limits
AI_REQUEST_TIMEOUT_MS=45000
FLOW_RUN_TIMEOUT_MS=60000
